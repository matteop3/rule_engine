# ==============================================================================
# Rule Engine - Environment Configuration
# ==============================================================================
# Copy this file to .env and update the values accordingly.
# ==============================================================================

# ------------------------------------------------------------------------------
# Application
# ------------------------------------------------------------------------------

# Environment mode: development, production, test
ENVIRONMENT=development

# Debug mode (WARNING: must be disabled in production)
DEBUG=false

# API version prefix
API_V1_STR=/api/v1

# ------------------------------------------------------------------------------
# Database
# ------------------------------------------------------------------------------
# When running with Docker Compose, DATABASE_URL is overridden by the value
# defined in docker-compose.yml to use the internal Docker network.
# The value below is used only when running the application without Docker.

# SQLite (local development without Docker)
# DATABASE_URL=sqlite:///./rule_engine.db

# PostgreSQL (connects to Docker container from host machine)
DATABASE_URL=postgresql://rule_engine_user:rule_engine_password@localhost:5432/rule_engine_db

# ------------------------------------------------------------------------------
# Security & Authentication
# ------------------------------------------------------------------------------

# Secret key for JWT tokens (REQUIRED - minimum 32 characters)
# Generate with: openssl rand -hex 32
SECRET_KEY=your_secret_key_here_must_be_at_least_32_characters_long

# JWT algorithm
JWT_ALGORITHM=HS256

# Access token expiration in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh token expiration in days
REFRESH_TOKEN_EXPIRE_DAYS=7

# Refresh token rotation
# When enabled, each refresh generates a new token and revokes the previous one
REFRESH_TOKEN_ROTATION=false

# ------------------------------------------------------------------------------
# Password Policy
# ------------------------------------------------------------------------------

PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGIT=true
PASSWORD_REQUIRE_SPECIAL=true

# ------------------------------------------------------------------------------
# CORS (Cross-Origin Resource Sharing)
# ------------------------------------------------------------------------------

# Allowed origins (comma-separated or JSON array)
# Examples:
#   Comma-separated: http://localhost:3000,http://localhost:8000
#   JSON array: ["http://localhost:3000","http://localhost:8000"]
BACKEND_CORS_ORIGINS=["http://localhost:8000","http://localhost:3000"]

# ------------------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------------------

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ------------------------------------------------------------------------------
# Rate Limiting
# ------------------------------------------------------------------------------

# Enable/disable rate limiting
RATE_LIMIT_ENABLED=true

# Login endpoint rate limits (brute force protection)
RATE_LIMIT_LOGIN_ATTEMPTS=5
RATE_LIMIT_LOGIN_WINDOW_MINUTES=15

# Refresh token endpoint rate limits
RATE_LIMIT_REFRESH_ATTEMPTS=10
RATE_LIMIT_REFRESH_WINDOW_MINUTES=5

# General API rate limit (requests per minute)
RATE_LIMIT_API_PER_MINUTE=60
