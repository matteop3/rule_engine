# ==================================================
# APPLICATION SETTINGS
# ==================================================

# Environment: development, production, test
ENVIRONMENT=development

# Enable debug mode (WARNING: Never enable in production!)
DEBUG=false

# API version prefix
API_V1_STR=/api/v1


# ==================================================
# DATABASE
# ==================================================

# SQLite (for development)
DATABASE_URL=sqlite:///./rule_engine.db

# PostgreSQL (recommended for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/rule_engine_db


# ==================================================
# SECURITY & AUTHENTICATION
# ==================================================

# Secret key for JWT tokens (REQUIRED - must be at least 32 characters)
# Generate with: openssl rand -hex 32
SECRET_KEY=your_secret_key_here_must_be_at_least_32_characters_long_generate_with_openssl

# JWT Algorithm
JWT_ALGORITHM=HS256

# Access token expiration (in minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh token expiration (in days)
REFRESH_TOKEN_EXPIRE_DAYS=7

# Refresh token rotation (recommended for production)
# If true, each refresh generates a new refresh token and revokes the old one
# If false, refresh token remains valid until expiration (simpler client-side)
REFRESH_TOKEN_ROTATION=false


# ==================================================
# PASSWORD POLICY
# ==================================================

# Minimum password length
PASSWORD_MIN_LENGTH=8

# Require uppercase letter
PASSWORD_REQUIRE_UPPERCASE=true

# Require lowercase letter
PASSWORD_REQUIRE_LOWERCASE=true

# Require digit
PASSWORD_REQUIRE_DIGIT=true

# Require special character
PASSWORD_REQUIRE_SPECIAL=true


# ==================================================
# CORS (Cross-Origin Resource Sharing)
# ==================================================

# Allowed origins (comma-separated or JSON array)
# Examples:
#   Comma-separated: http://localhost:3000,http://localhost:8000
#   JSON array: ["http://localhost:3000","http://localhost:8000"]
BACKEND_CORS_ORIGINS=http://localhost:8000,http://localhost:3000


# ==================================================
# LOGGING
# ==================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO


# ==================================================
# RATE LIMITING
# ==================================================

# Enable/disable rate limiting
RATE_LIMIT_ENABLED=true

# Login endpoint rate limits (prevents brute force attacks)
RATE_LIMIT_LOGIN_ATTEMPTS=5
RATE_LIMIT_LOGIN_WINDOW_MINUTES=15

# Refresh token endpoint rate limits
RATE_LIMIT_REFRESH_ATTEMPTS=10
RATE_LIMIT_REFRESH_WINDOW_MINUTES=5

# General API rate limit (requests per minute)
RATE_LIMIT_API_PER_MINUTE=60
